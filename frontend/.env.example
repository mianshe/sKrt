# Recommended default: same-origin /api (works for production and local Vite proxy)
VITE_API_BASE=/api

# If you debug in an IDE embedded preview (which bypasses Vite proxy), you can set:
# VITE_API_BASE=http://127.0.0.1:8000
# After editing env, restart Vite and hard-refresh browser (or clear cache).

# Production setup:
# - Frontend env: VITE_API_BASE=/api
# - Reverse proxy: /api -> uvicorn
