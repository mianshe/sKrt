{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sKrt Desktop",
  "version": "0.1.0",
  "identifier": "com.sciomenihilscire.skrt.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../../frontend run dev -- --host 127.0.0.1 --port 5173",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm --prefix ../../frontend run build",
    "frontendDist": "../../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "sKrt Desktop",
        "width": 1360,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "targets": "all",
    "category": "Education",
    "shortDescription": "sKrt desktop client",
    "longDescription": "Desktop client scaffold for sKrt with future local-first storage capabilities."
  }
}
