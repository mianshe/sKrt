# 复制到云主机后改名为 .env 并填写密钥；勿将含真实密钥的 .env 提交到 Git。
# 后端读进程环境变量：systemd 可用 EnvironmentFile=/path/to/.env

DATABASE_URL=

# ---------- AI 推理（至少配置一种）----------
GITHUB_TOKEN=
ZHIPU_API_KEY=
HF_TOKEN=
HYBRID_LOCAL_FIRST=0

# ---------- 租户 ----------
TENANT_IP_AS_DEFAULT=1
TENANT_REQUIRE_HEADER=0
TENANT_HEADER_NAME=X-Tenant-Id
TENANT_DEFAULT_ID=public

# ---------- Paddle 本地（与百度 / 外部 HTTP OCR 无关）----------
PADDLEOCR_USE_GPU=auto

# ---------- 百度智能云 OCR（控制台 API Key 与 Secret Key 两个都要填）----------
BAIDU_OCR_API_KEY=Tyw0cSaqnvV9GbUYSrzq7DGf
BAIDU_OCR_SECRET_KEY=RdTLpKLCx05DEYOlBhautX0HJHAqpb4d
# BAIDU_OCR_PRODUCT=accurate_basic
# BAIDU_OCR_URL=https://aip.baidubce.com/rest/2.0/ocr/v1/accurate_basic

# ---------- 外部 HTTP OCR（自建服务 POST {OCR_API_BASE}/ocr/pdf；不是百度）----------
OCR_API_BASE=
OCR_API_KEY=
OCR_API_TIMEOUT_SEC=900
# 兼容旧名：GPU_OCR_ENDPOINT、GPU_OCR_API_KEY、GPU_OCR_TIMEOUT_SEC

# ---------- PDF 引擎（可选）auto|paddle|tesseract|baidu|remote|ocr_api|api|runpod|gpu ----------
# PDF_OCR_ENGINE=auto
# PDF_OCR_REMOTE_FIRST=1
# PDF_OCR_BAIDU_FALLBACK=1

# ---------- Cloudflare R2（仅后端）----------
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_BUCKET=xm1-docs
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DELETE_LOCAL_AFTER_UPLOAD=1
R2_REGION=auto
R2_STORAGE_PREFIX=xm1

INGEST_SCAN_CHUNK_SIZE=480
INGEST_SCAN_CHUNK_OVERLAP=120
INGEST_STAGE_BATCH_SIZE=8

CAPACITY_DISK_SOFT_LIMIT_BYTES=3221225472
CAPACITY_DISK_HARD_LIMIT_BYTES=1073741824
CAPACITY_PAUSE_ON_HARD_LIMIT=1

CHAT_MEMORY_TTL_SECONDS=0
CHAT_MEMORY_RECENT_LIMIT=6

APP_ENV=dev

# CORS：前后端不同源且 fetch 带 credentials 时填写，逗号分隔，无尾斜杠
# CORS_ALLOW_ORIGINS=https://your-frontend.example.com

AUTH_JWT_ENABLED=0
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_JWT_JWKS_URL=
AUTH_JWT_LEEWAY_SECONDS=60
AUTH_REQUIRE_MEMBERSHIP_CHECK=1
AUTH_TENANT_CLAIM_KEY=tenant_id
AUTH_ROLES_CLAIM_KEY=roles
AUTH_PERMISSIONS_CLAIM_KEY=permissions

TENANT_DEFAULT_MAX_DOCUMENTS=1000
TENANT_DEFAULT_MAX_VECTORS=1000000
TENANT_DEFAULT_MAX_STORAGE_BYTES=5368709120

CLEANUP_ENABLED=1
CLEANUP_INTERVAL_HOURS=168
CLEANUP_CHUNK_RETENTION_HOURS=24
CLEANUP_OCR_CACHE_RETENTION_HOURS=72
CLEANUP_FAILED_FILE_RETENTION_HOURS=168
CLEANUP_DOCUMENT_RETENTION_DAYS=30

