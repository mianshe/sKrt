# =============================================================================
# xm1 后端环境变量示例：复制为 .env 后填写真实值。勿将含密钥的 .env 提交到 Git。
# 进程读环境变量；systemd 可用 EnvironmentFile=/path/to/.env
# =============================================================================

# -----------------------------------------------------------------------------
# 知识库与 PostgreSQL
# -----------------------------------------------------------------------------
# DATABASE_URL 留空：知识库用本地 SQLite（data/knowledge.db），适合单机小站。
# DATABASE_URL 填写且 KNOWLEDGE_STORE=postgres：文档/向量/图谱写入 PostgreSQL。
#   与本机 PG 同机：postgresql://用户:密码@127.0.0.1:5432/库名
#   云托管（Neon/腾讯云等）：用控制台 URI；境外服务常需 ?sslmode=require
# 深度报告流水线、生产 JWT 等已接 PG 的能力会随 DATABASE_URL 启用。
DATABASE_URL=
# 知识库存储：不设或空 = sqlite | 设为 postgres = 使用 DATABASE_URL（须已配置）
#KNOWLEDGE_STORE=postgres
# 已有 data/knowledge.db 需迁 PG：设置好 DATABASE_URL 后运行
#   py backend/scripts/migrate_knowledge_sqlite_to_pg.py
# 兼容别名：POSTGRES_URL（部分脚本可读）

# -----------------------------------------------------------------------------
# 对象存储：上传原件（PDF 等）
# -----------------------------------------------------------------------------
# 推荐架构：原件只上云（R2），向量与索引在主机 SQLite 或上方 PostgreSQL。
# 配全下列项后 upload 会写 r2://；R2_DELETE_LOCAL_AFTER_UPLOAD=1 可省本机磁盘。
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_BUCKET=xm1-docs
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DELETE_LOCAL_AFTER_UPLOAD=1
R2_REGION=auto
R2_STORAGE_PREFIX=xm1

# 未配置 R2 时可选：Supabase Storage 作为上传兜底（file_path 为 supabase://）
# 需与上方 DATABASE_URL 区分：此为「文件桶」，不是 Postgres 连接串。
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents
SUPABASE_STORAGE_PREFIX=xm1
SUPABASE_DELETE_LOCAL_AFTER_UPLOAD=0

# ---------- AI 推理（至少配置一种）----------
GITHUB_TOKEN=
ZHIPU_API_KEY=
HF_TOKEN=
HYBRID_LOCAL_FIRST=0

# ---------- 租户 ----------
TENANT_IP_AS_DEFAULT=1
TENANT_REQUIRE_HEADER=0
TENANT_HEADER_NAME=X-Tenant-Id
TENANT_DEFAULT_ID=public

# ---------- Paddle 本地（与百度 / 外部 HTTP OCR 无关）----------
PADDLEOCR_USE_GPU=auto

# ---------- 百度智能云 OCR（控制台 API Key 与 Secret Key 两个都要填）----------
# 扫描件 PDF 超过约 10MB 时可能提示外部 OCR；该阈值当前为后端代码常量（main.py），未通过本文件环境变量暴露。
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
# BAIDU_OCR_PRODUCT=accurate_basic
# BAIDU_OCR_URL=https://aip.baidubce.com/rest/2.0/ocr/v1/accurate_basic

# ---------- 外部 HTTP OCR（自建服务 POST {OCR_API_BASE}/ocr/pdf；不是百度）----------
OCR_API_BASE=
OCR_API_KEY=
OCR_API_TIMEOUT_SEC=900
# 兼容旧名：GPU_OCR_ENDPOINT、GPU_OCR_API_KEY、GPU_OCR_TIMEOUT_SEC

# ---------- PDF 引擎（可选）auto|paddle|tesseract|baidu|remote|ocr_api|api|runpod|gpu ----------
# PDF_OCR_ENGINE=auto
# PDF_OCR_REMOTE_FIRST=1
# PDF_OCR_BAIDU_FALLBACK=1

INGEST_SCAN_CHUNK_SIZE=480
INGEST_SCAN_CHUNK_OVERLAP=120
INGEST_STAGE_BATCH_SIZE=8

CAPACITY_DISK_SOFT_LIMIT_BYTES=3221225472
CAPACITY_DISK_HARD_LIMIT_BYTES=1073741824
CAPACITY_PAUSE_ON_HARD_LIMIT=1

CHAT_MEMORY_TTL_SECONDS=0
CHAT_MEMORY_RECENT_LIMIT=6

APP_ENV=dev

# CORS：前后端不同源且 fetch 带 credentials 时填写，逗号分隔，无尾斜杠
# CORS_ALLOW_ORIGINS=https://your-frontend.example.com

AUTH_JWT_ENABLED=0
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_JWT_JWKS_URL=
AUTH_JWT_LEEWAY_SECONDS=60
AUTH_REQUIRE_MEMBERSHIP_CHECK=1
AUTH_TENANT_CLAIM_KEY=tenant_id
AUTH_ROLES_CLAIM_KEY=roles
AUTH_PERMISSIONS_CLAIM_KEY=permissions

# ---------- 本地邮箱注册（HS256 JWT，与上方 AUTH_JWT_* 可同时存在：Bearer 先尝试本地再尝试 JWKS）----------
# 设置随机密钥（建议 32+ 字符）后启用 POST /auth/register/*、/auth/login、/health.auth_local_jwt_enabled
AUTH_LOCAL_JWT_SECRET=
AUTH_LOCAL_JWT_ISSUER=xm1-local
AUTH_LOCAL_JWT_AUDIENCE=xm1-web
AUTH_LOCAL_JWT_TTL_SEC=604800
# 开启后未登录用户无法调用服务器入库接口；与公告「游客数据仅保存在本机浏览器」一致（匿名仅用 IndexedDB，见前端 UploadTab）
AUTH_INGEST_REQUIRES_LOGIN=1
# 新用户注册赠送外部 OCR 次数（与公告「100 次 OCR 请求」、余额扣减单位一致）。代码优先读 CALLS，未设时回退 PAGES / GPU_OCR_INITIAL_FREE_*。
SIGNUP_FREE_OCR_CALLS=100
# 兼容旧名（与 SIGNUP_FREE_OCR_CALLS 择一生效，任选其一即可）
#SIGNUP_FREE_OCR_PAGES=100
# 同一公网 IP（终身）最多给几个不同邮箱各送一份新人礼（与公告「同 IP 最多三个邮箱」一致）
SIGNUP_MAX_FREE_GRANTS_PER_IP_LIFETIME=3
# 反代后信任 X-Forwarded-For（仅部署在受信反代后设为 1）
TRUST_PROXY_HEADERS=0
# 开发调试：SMTP 未配时在响应中回显验证码（切勿用于生产）
AUTH_REGISTER_ECHO_CODE=0

TENANT_DEFAULT_MAX_DOCUMENTS=1000
TENANT_DEFAULT_MAX_VECTORS=1000000
# 每租户云端原件等占用上限，默认 100MiB（104857600），与公告「每账号云端约 100MB」一致；原件多在 R2，按对象存储占用计；超额时上传/入库可能受限。覆盖租户上限见 PostgreSQL tenant_quotas
TENANT_DEFAULT_MAX_STORAGE_BYTES=104857600

CLEANUP_ENABLED=1
CLEANUP_INTERVAL_HOURS=168
CLEANUP_CHUNK_RETENTION_HOURS=24
CLEANUP_OCR_CACHE_RETENTION_HOURS=72
CLEANUP_FAILED_FILE_RETENTION_HOURS=168
# 入库文档数据保留天数，与公告「最长保留约 30 天」一致；由定时清理任务执行，以服务端实际任务为准
CLEANUP_DOCUMENT_RETENTION_DAYS=30

Environment=SIGNUP_FREE_OCR_CALLS=100
Environment=SIGNUP_MAX_FREE_GRANTS_PER_IP_LIFETIME=3

# ---------- 支付（易支付）：以下为占位，请换成你自己的商户参数 ----------
PAY_PROVIDER=easypay
PAY_NOTIFY_URL=
PAY_RETURN_URL=
PAY_REFUND_ENABLED=1
PAY_REFUND_ADMIN_KEY=
EASYPAY_API_BASE=
EASYPAY_PID=
EASYPAY_KEY=
# Optional compatibility alias for some deployments
EASYPAY_RETURN_URL=

# ---------- 外部 OCR 次数（与余额扣减单位一致；每租户 + client_id，见 gpu_ocr_paid_pages_balance）----------
# 上传时仅做余额是否覆盖预估用量的预检，不预扣；解析入库后按百度/远程 OCR 实际成功 HTTP 次数扣减（与公告「直接调用服务商 API、以运营商为准」一致）。
GPU_OCR_INITIAL_FREE_CALLS=100
# 兼容旧名：GPU_OCR_INITIAL_FREE_PAGES
# GPU_OCR_INITIAL_FREE_PAGES=100
# 兼容旧名：GPU_OCR_DAILY_PAGE_LIMIT / GPU_OCR_MONTHLY_GLOBAL_PAGE_LIMIT
# GPU_OCR_DAILY_CALL_LIMIT=100
# GPU_OCR_MONTHLY_GLOBAL_CALL_LIMIT=3000

# ---------- 随机码邮件 ----------
# 隐藏入口（例如特殊用户解锁 special_unlock、主控补额 gpu_redeem）生成的随机码只会发送到此邮箱（主控用）。
# 提醒：不要把真实邮箱提交到 Git；线上/本机用自己的 .env 配置即可。
CODE_EMAIL_TO=
CODE_EMAIL_TTL_SEC=600
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=1

# ---------- RunPod 整库入库（与 OCR_API 单 PDF 不同）----------
RUNPOD_ENABLED=0
RUNPOD_INGEST_ENDPOINT=
RUNPOD_API_KEY=
RUNPOD_TIMEOUT_SEC=30
RUNPOD_CALLBACK_URL=
RUNPOD_CALLBACK_SECRET=

# ---------- GPU 云主机自动启停 ----------
GPU_AUTOSTART_ENABLED=0
GPU_AUTOSTART_PROVIDER=tencent
GPU_AUTOSTOP_IDLE_SECONDS=120
GPU_AUTOSTART_TENCENT_SECRET_ID=
GPU_AUTOSTART_TENCENT_SECRET_KEY=
GPU_AUTOSTART_TENCENT_REGION=
GPU_AUTOSTART_TENCENT_INSTANCE_IDS=
GPU_AUTOSTART_ALIYUN_ACCESS_KEY_ID=
GPU_AUTOSTART_ALIYUN_ACCESS_KEY_SECRET=
GPU_AUTOSTART_ALIYUN_REGION=
GPU_AUTOSTART_ALIYUN_INSTANCE_IDS=
